---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};

const navLinks = [
  { href: "/posts", label: "Posts" },
  { href: "/notes", label: "Notes" },
  { href: "/projects", label: "Projects" },
  { href: "/tags", label: "Tags" },
  { href: "/about", label: "About" },
];
---

<header
  class="sticky top-0 z-40 w-full border-b border-border/50 bg-background/95 backdrop-blur-md"
>
  <a
    id="skip-to-content"
    href="#main-content"
    class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent transition-all focus:top-4"
  >
    Skip to content
  </a>

  <div class="mx-auto flex h-14 max-w-app items-center justify-between px-4">
    <!-- Logo / left -->
    <a
      href="/"
      class="shrink-0 text-lg font-bold tracking-tight text-foreground hover:text-accent"
    >
      {SITE.title}
    </a>

    <!-- Center nav links (desktop) -->
    <nav class="hidden sm:flex sm:items-center sm:gap-6" aria-label="Main">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "label py-1 transition-colors hover:text-accent",
            isActive(href) ? "nav-active" : "text-foreground/70",
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Right side: search + theme + mobile menu -->
    <div class="flex items-center gap-2">
      <a
        href="/search"
        class:list={[
          "flex items-center p-2 text-foreground/70 transition-colors hover:text-accent",
          { "text-accent": isActive("/search") },
        ]}
        aria-label="Search"
        title="Search"
      >
        <IconSearch class="size-[18px]" />
      </a>

      {SITE.lightAndDarkMode && (
        <button
          id="theme-btn"
          class="relative flex size-9 items-center justify-center text-foreground/70 transition-colors hover:text-accent"
          title="Toggles light & dark"
          aria-label="auto"
          aria-live="polite"
        >
          <IconMoon class="absolute size-[18px] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
          <IconSunHigh class="absolute size-[18px] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
        </button>
      )}

      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="flex items-center p-2 text-foreground/70 transition-colors hover:text-accent sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <IconX id="close-icon" class="hidden size-5" />
        <IconMenuDeep id="menu-icon" class="size-5" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-border/50 bg-background px-4 pb-4 sm:hidden"
    aria-label="Mobile"
  >
    <ul class="flex flex-col gap-1 pt-2">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "label block py-2 transition-colors hover:text-accent",
              isActive(href) ? "nav-active" : "text-foreground/70",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const mobileMenu = document.querySelector("#mobile-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !mobileMenu || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      mobileMenu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>
