---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { Image } from "astro:assets";
import prof2 from "@/assets/images/prof2.jpeg";
---

<Layout title={`About | ${SITE.title}`}>
  <Header />
  <main id="main-content">
    <article class="about">

      <!-- Avatar — floats right so body text wraps around it -->
      <div class="about-avatar">
        <Image
          src={prof2}
          alt="Mounir Samite"
          width={150}
          height={150}
          class="about-avatar-img"
        />
        <div class="scanlines" aria-hidden="true"></div>
      </div>

      <!-- Header -->
      <h1 class="about-name">Mounir Samite</h1>
      <p class="about-tagline">ciao, I'm glad you're here</p>
      <div class="about-chips">
        <span class="chip">// Italy</span>
        <span class="chip">// Agents</span>
        <span class="chip">// Software architecture</span>
        <span class="chip">// gym, sports and martial arts</span>
      </div>

      <!-- Body text with terminal labels -->
      <div class="tl fade-in">&gt; init: who_am_i</div>
      <p class="body">I'm a 23 yo computer science engineering student from Italy, finishing my Master's at the University of Bologna. I study distributed systems, complex architectures, and how machines learn, all because I'm convinced that intelligent agents are going to change how we interact with software.</p>

      <div class="tl fade-in">&gt; loading: projects[]</div>
      <p class="body">I like building things. Right now I'm working on a startup, juggling way too many course projects at once, and somehow making it work. People who know me say I always have too many things going on, that's because I believe in limit testing, which consist in doing things that seem impossible, to figure out what I'm capable of.</p>
      <p class="body">I care about making software that actually helps people live better, not just software that looks good on a pitch deck. I'm ambitious, but I'd rather be honest and build slow than fake it and move fast.</p>

      <div class="tl fade-in">&gt; status: offline_sometimes</div>
      <p class="body">When I'm not at my desk I'm at the gym, playing sports with friends, or trying (and sometimes failing) to take a full Sunday off. I question everything I do, whether I'm spending my time right, whether the work is good enough. It's annoying, but it's also why I keep getting better.</p>

      <div class="tl fade-in">&gt; core_belief:</div>
      <p class="body">I believe the best technology removes the boring stuff from people's lives and gives them space for what actually requires a human: creativity, judgment, putting things together in ways no machine would. That's what I want to build.</p>

      <!-- Closing line with blinking cursor -->
      <p class="closing fade-in">Still here? Good taste. Stick around<span class="cursor" aria-hidden="true">|</span></p>

    </article>
  </main>
  <Footer />
</Layout>

<style>
  /* ===== Layout ===== */
  .about {
    max-width: 650px;
    margin: 0 auto;
    padding: 3rem 1rem 6rem;
  }

  /* ===== Avatar float ===== */
  .about-avatar {
    float: right;
    width: 150px;
    height: 150px;
    shape-outside: circle(50%);
    shape-margin: 1rem;
    margin: 0.25rem 0 1rem 1rem;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--accent);
    position: relative;
    transition: box-shadow 0.3s ease;
  }
  .about-avatar:hover {
    box-shadow: 0 0 24px color-mix(in srgb, var(--accent) 20%, transparent);
  }
  .about-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: none !important;
  }

  /* Scanline overlay — visible on hover */
  .scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 2px,
      rgba(0, 0, 0, 0.12) 2px,
      rgba(0, 0, 0, 0.12) 4px
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    border-radius: 50%;
  }
  .about-avatar:hover .scanlines {
    opacity: 1;
  }

  /* ===== Header ===== */
  .about-name {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--headings);
    margin: 0 0 0.4rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .about-tagline {
    color: var(--accent);
    font-size: 0.95rem;
    font-style: italic;
    margin: 0 0 1.25rem;
    font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* Chips */
  .about-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }
  .chip {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    background: var(--muted);
    border: 1px solid var(--border);
    padding: 0.25rem 0.65rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  /* ===== Terminal labels ===== */
  .tl {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.8rem;
    color: var(--accent);
    opacity: 0.7;
    margin: 2rem 0 0.75rem;
  }
  .about-chips + .tl {
    margin-top: 0.5rem;
  }

  /* ===== Body text ===== */
  .body {
    font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--foreground);
    margin: 0 0 1rem;
  }

  /* ===== Closing line ===== */
  .closing {
    font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    font-size: 1.15rem;
    font-style: italic;
    color: var(--accent);
    margin: 2.5rem 0 0;
    line-height: 1.6;
    clear: both;
  }

  /* Blinking cursor */
  .cursor {
    display: inline-block;
    margin-left: 2px;
    font-style: normal;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ===== Fade-in on scroll ===== */
  .fade-in {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== Responsive ===== */
  @media (max-width: 500px) {
    .about-avatar {
      float: none;
      display: block;
      margin: 0 auto 1.5rem;
      shape-outside: none;
    }
    .about-name {
      font-size: 1.7rem;
      text-align: center;
    }
    .about-tagline {
      text-align: center;
    }
    .about-chips {
      justify-content: center;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15 }
    );
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  });
</script>
