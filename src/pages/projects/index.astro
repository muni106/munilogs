---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ProjCard from "@/components/ProjCard.astro";
import { SITE } from "@/config";
import projectsData from "@/data/projects.json";
import manualProjectsData from "@/data/projects.manual.json";

type Project = {
  name: string;
  url: string;
  description: string;
  tagline: string;
  status: string;
  tags: string[];
  cover: string | null;
  stars: number;
  language: string | null;
  lastCommit: string | null;
  order?: number;
  featured?: boolean;
};

const projects = projectsData as Project[];
const manualProjects = manualProjectsData as Project[];

const statusGroups = [
  { key: "active", label: "> active" },
  { key: "completed", label: "> completed" },
  { key: "contribution", label: "> open-source contributions" },
] as const;

const statusRank: Record<string, number> = { active: 0, completed: 1, contribution: 2 };
const merged: Project[] = [...projects, ...manualProjects]
  .filter((p, i, arr) => arr.findIndex(x => x.name === p.name) === i)
  .sort((a, b) => {
    const sa = statusRank[a.status] ?? 99;
    const sb = statusRank[b.status] ?? 99;
    if (sa !== sb) return sa - sb;
    const oa = a.order ?? 99;
    const ob = b.order ?? 99;
    if (oa !== ob) return oa - ob;
    return new Date(b.lastCommit ?? 0).getTime() - new Date(a.lastCommit ?? 0).getTime();
  });

const grouped = statusGroups
  .map(g => ({
    ...g,
    items: merged.filter(p => p.status === g.key),
  }))
  .filter(g => g.items.length > 0);
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Projects" pageDesc="some selected projects :)">
    {grouped.map(group => (
      <div class="proj-group">
        <div class="proj-group-label">{group.label}</div>
        <div class="proj-grid">
          {group.items.map(project => <ProjCard {project} />)}
        </div>
      </div>
    ))}
  </Main>
  <Footer />
</Layout>

<style>
  .proj-group {
    margin-bottom: 2.5rem;
  }
  .proj-group-label {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.8rem;
    color: var(--accent);
    opacity: 0.7;
    margin-bottom: 1rem;
  }
  .proj-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
</style>
